# ══════════════════════════════════════════════════════════════
# PsicoMap — Variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env — ele está no .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Ambiente ────────────────────────────────────────────────────
# 'development' mostra banner azul na tela, aponta para Supabase dev
# 'production' é limpo, aponta para Supabase prod
APP_ENV=development

# ── Supabase ────────────────────────────────────────────────────
# DEV:  URL e chave anon do projeto psicomap-dev no Supabase
# PROD: URL e chave anon do projeto psicomap-prod no Supabase
SUPA_URL=https://SEU_PROJETO_DEV.supabase.co
SUPA_ANON=eyJhbGci...sua_chave_anon_dev...

# ── Stripe ──────────────────────────────────────────────────────
# DEV:  usar chaves test_ e links de teste
# PROD: usar chaves live_ e links reais
STRIPE_MODE=test

STRIPE_STARTER=https://buy.stripe.com/test_...
STRIPE_PRO=https://buy.stripe.com/test_...
STRIPE_ENT=https://buy.stripe.com/test_...
