# PsicoMap — Cloudflare Pages redirects
# Documentação: https://developers.cloudflare.com/pages/configuration/redirects/

# Rota pública do formulário de coleta
/form         /psicomap-forms.html         200
/form/*       /psicomap-forms.html         200

# Painel admin (raiz já redireciona via index.html)
/admin        /psicomap-admin.html  200
/admin/*      /psicomap-admin.html  200

# Arquivos SQL e Markdown: bloquear acesso direto
/**.sql       /404.html                403
/**.md        /404.html                403
